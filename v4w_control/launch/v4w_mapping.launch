<launch>
	<arg name="robot_name" default="$(optenv HOSTNAME v4w1)"/>
	<include file="$(find v4w_control)/launch/v4w_camera.launch">
		<arg name="robot_name" value="$(arg robot_name)"/>
	</include>
	<group ns="$(arg robot_name)">
		<!-- elevation mapping -->
		<env name="PYTHONPATH" value="/home/jetson/.local/lib/python3.8/site-packages:$(env PYTHONPATH)" />
		<node pkg="elevation_mapping_cupy" type="elevation_mapping_node" name="elevation_mapping" output="screen">
			<rosparam command="load" file="$(find v4w_control)/config/mapping_param_rgb.yaml" />
			<!-- Override subscriber topics to match camera driver -->
			<param name="subscribers/color_cam/topic_name" value="/$(arg robot_name)/rgb/image_raw" />
			<param name="subscribers/color_cam/camera_info_topic_name" value="/$(arg robot_name)/rgb/camera_info" />
			<param name="subscribers/front_cam_pointcloud/topic_name" value="/$(arg robot_name)/points2" />

			<!-- Frame parameters that need environment variable substitution -->
			<param name="map_frame" value="odom"/>
			<param name="base_frame" value="$(arg robot_name)/base_link"/>
			<param name="corrected_map_frame" value="odom"/>
			<param name="pointcloud_topics" value="[/$(arg robot_name)/points2]" type="yaml"/>
		</node>

	</group>
</launch>
